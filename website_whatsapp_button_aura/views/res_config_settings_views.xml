<?xml version="1.0" encoding="utf-8"?>
<odoo>
      <!-- Inherit res.config.settings form view -->
      <record id="res_config_settings_view_form_whatsapp" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.whatsapp</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="website.res_config_settings_view_form" />
            <field name="arch" type="xml">
                  <xpath expr="//app[@name='website']//block[@id='website_info_settings']"
                        position="after">
                        <block title="WhatsApp Button" id="whatsapp_button_settings">
                              <setting id="whatsapp_button_enabled_setting"
                                    string="WhatsApp Chat Button"
                                    help="Show a floating WhatsApp button on your website">
                                    <field name="whatsapp_button_enabled" />
                              </setting>
                              <setting id="whatsapp_phone_setting"
                                    string="Phone Number"
                                    help="WhatsApp phone number with country code"
                                    invisible="not whatsapp_button_enabled">
                                    <field name="whatsapp_phone_number" placeholder="+1234567890" />
                              </setting>
                              <setting id="whatsapp_message_setting"
                                    string="Default Message"
                                    help="Pre-filled message for visitors"
                                    invisible="not whatsapp_button_enabled">
                                    <field name="whatsapp_default_message"
                                          placeholder="Hello! I have a question..." />
                              </setting>
                              <setting id="whatsapp_position_setting"
                                    string="Button Position"
                                    invisible="not whatsapp_button_enabled">
                                    <field name="whatsapp_button_position" widget="radio"
                                          options="{'horizontal': true}" />
                              </setting>
                              <setting id="whatsapp_size_setting"
                                    string="Button Size"
                                    invisible="not whatsapp_button_enabled">
                                    <field name="whatsapp_button_size" widget="radio"
                                          options="{'horizontal': true}" />
                              </setting>
                              <setting id="whatsapp_tooltip_setting"
                                    string="Tooltip Text"
                                    invisible="not whatsapp_button_enabled">
                                    <field name="whatsapp_tooltip_text"
                                          placeholder="Chat with us on WhatsApp" />
                              </setting>
                        </block>
                  </xpath>
            </field>
      </record>
</odoo>