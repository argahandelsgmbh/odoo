<odoo>
    <data>

        <record id="sale_order_form_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                 <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="open_related_po" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not purchase_count">
                        <field name="purchase_count" widget="statinfo" string="PURCHASES"/>
                    </button>
                </xpath>

                <xpath expr="//field[@name='date_order'][2]" position="replace">
                    <field name="date_order" nolabel="1"/>
                </xpath>

                <xpath expr="//field[@name='commitment_date']" position="replace">
                    <field name="commitment_date" string="Expected Date" readonly="0"/>
                </xpath>

                <xpath expr="//field[@name='note']" position="after">
                <field name="purchase_order_ids" invisible="not purchase_order_ids"/>
                <field name="payment_ids" invisible="not payment_ids"/>
                <field name="invoice_ids" string="Faturalar" invisible="not invoice_ids"/>
                <field name="picking_ids" string="Teslimatlar" invisible="not picking_ids"/>
                </xpath>

                <xpath expr="//header" position="inside">
                    <button string="Create Payment" type="object" name="action_open_payment"/>
                </xpath>

                <div name="button_box" position="inside">
                    <button type="object" class="oe_stat_button" icon="fa-dollar" name="action_show_payments">
                        <field string="Payments" name="payment_count" widget="statinfo"/>
                    </button>
                </div>

            </field>
        </record>


         <template id="report_invoice_document_inherit_downpayment_summaryy" inherit_id="account.report_invoice_document">

            <xpath expr="//div[@class='overflow-hidden']" position="attributes">
                <attribute name="class">overflow-hidden row</attribute>
            </xpath>

            <xpath expr="//div[@id='right-elements']" position="attributes">
                <attribute name="class">col-6 mt-3</attribute>
            </xpath>

            <xpath expr="//div[@id='right-elements']" position="before">
                <div class="col-6 mt-5" >
                    <br/>
                    <table class="o_total_table table table-borderless">
                    <tr>
                        <td class="colspan-2"><strong>Order Payment Summary</strong></td>
                    </tr>
                    <tr>
                        <td>Total Order Amount:</td>
                        <td class="text-end">
                            <span t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                    <tr>
                        <td>Advance payments (down payments):</td>
                        <td class="text-end">
                                                    <span t-esc="so.total_payment" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                    <tr>
                        <td>Already Paid:</td>
                        <td class="text-end">
                                                   <span t-esc="so.total_payment" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Remaining Balance:</strong></td>
                        <td class="text-end">
                            <strong>
                                                           <span t-esc="so.total_open_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </strong>
                        </td>
                    </tr>
                </table>
                </div>
            </xpath>

        </template>


    </data>
</odoo>
